# AI Customer Support (AICS) Environment Variables

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant Cloud Configuration
# Get from: https://cloud.qdrant.io/
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Session Secret (required for secure sessions)
# Generate a strong secret key, e.g., using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# Neon (PostgreSQL) Database URL
# Get from: https://console.neon.tech/
# If not provided, app will use JSON file storage
DATABASE_URL=postgresql://user:password@hostname:5432/dbname
